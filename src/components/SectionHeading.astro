---
interface Props {
  id?: string;
  title: string;
  subtitle?: string;
}

const { id, title, subtitle } = Astro.props;
---

<header class="mb-6">
  <h2 id={id} class="text-2xl font-semibold text-white tracking-tight">{title}</h2>
  {subtitle && <p class="mt-1 text-slate-400">{subtitle}</p>}
</header>
